{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Next.js tsconfig",
  "extends": "./tsconfig-base.json",
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["DOM", "ES2025"],
    "jsx": "preserve",
    "moduleResolution": "Bundler",
    "module": "Preserve",
    "noEmit": true,
    "skipLibCheck": true,
    "plugins": [{ "name": "next" }]
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx"]
}
